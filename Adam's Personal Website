    <script>
        (function() {
            // ---------- SCROLL HIDE HEADER ----------
            const header = document.getElementById('mainHeader');
            let lastScrollY = window.scrollY;
            let ticking = false;

            function updateHeader() {
                const currentScrollY = window.scrollY;
                if (currentScrollY > lastScrollY && currentScrollY > 80) {
                    // scrolling down
                    header.classList.add('hide-header');
                } else {
                    // scrolling up
                    header.classList.remove('hide-header');
                }
                lastScrollY = currentScrollY;
                ticking = false;
            }

            window.addEventListener('scroll', () => {
                if (!ticking) {
                    window.requestAnimationFrame(updateHeader);
                    ticking = true;
                }
            });

            // ---------- PROJECT DATA ----------
            const projects = [
                { title: "Neon Rebrand", shortDesc: "Complete visual identity for a cyberpunk brand.", icon: "fa-paint-brush", fullDesc: "Full brand overhaul. Logo suite, palette, typography, brand guidelines.", tech: ["Photoshop", "Illustrator", "Figma"] },
                { title: "Afterglow Edit", shortDesc: "Cinematic music video edit – 1.2M views.", icon: "fa-video", fullDesc: "4K music video with VFX compositing and custom LUTs.", tech: ["Premiere Pro", "After Effects", "DaVinci"] },
                { title: "Cyber Portfolio", shortDesc: "This website – responsive & neon-infused.", icon: "fa-code", fullDesc: "Personal portfolio with cyberpunk theme, reveal animations, modal system.", tech: ["HTML5", "CSS3", "JavaScript"] },
                { title: "3D Motion", shortDesc: "Blender animations and motion graphics.", icon: "fa-cubes", fullDesc: "Procedural 3D loops for branding. Rendered in Cycles.", tech: ["Blender", "After Effects"] }
            ];

            const grid = document.getElementById('portfolioGrid');
            function renderPortfolio() {
                grid.innerHTML = '';
                projects.forEach((proj, i) => {
                    const card = document.createElement('div');
                    card.className = 'project-card';
                    card.innerHTML = `<div class="card-img"><i class="fas ${proj.icon}"></i></div>
                        <div class="card-content"><h3>${proj.title}</h3><p>${proj.shortDesc}</p>
                        <button class="card-btn" data-index="${i}">View Details</button></div>`;
                    grid.appendChild(card);
                });
            }
            renderPortfolio();

            // ---------- MODAL ----------
            const modal = document.getElementById('projectModal');
            const modalContent = document.getElementById('modalContent');
            document.getElementById('closeModalBtn').addEventListener('click', () => {
                modal.style.display = 'none';
                document.body.style.overflow = '';
            });
            modal.addEventListener('click', (e) => { if (e.target === modal) { modal.style.display = 'none'; document.body.style.overflow = ''; } });
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.style.display === 'flex') { modal.style.display = 'none'; document.body.style.overflow = ''; } });

            grid.addEventListener('click', (e) => {
                const btn = e.target.closest('.card-btn');
                if (btn && btn.dataset.index !== undefined) {
                    const p = projects[btn.dataset.index];
                    modalContent.innerHTML = `<div class="modal-img"><i class="fas ${p.icon}"></i></div>
                        <div class="modal-title">${p.title}</div><div class="modal-body"><p class="modal-desc">${p.fullDesc}</p>
                        <div class="modal-tech">${p.tech.map(t => `<span class="tech-tag">${t}</span>`).join('')}</div>
                        <p style="margin-top:30px;opacity:0.7;">🔗 More details available upon request.</p></div>`;
                    modal.style.display = 'flex';
                    document.body.style.overflow = 'hidden';
                }
            });

            // ---------- PROGRESS BARS & REVEAL ----------
            const bars = document.querySelectorAll('.progress-fill');
            function animateBars() { bars.forEach(b => { const t = b.getAttribute('data-target'); if (t) b.style.width = t + '%'; }); }
            const revealEls = document.querySelectorAll('.reveal');
            const obs = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        if (entry.target.id === 'skills') animateBars();
                    }
                });
            }, { threshold: 0.2 });
            revealEls.forEach(el => obs.observe(el));
            window.addEventListener('load', () => { animateBars(); if (document.getElementById('skills')?.getBoundingClientRect().top < window.innerHeight) animateBars(); });

            // ---------- CONTACT FORM (Formspree) ----------
            const form = document.getElementById('contactForm');
            const feedback = document.getElementById('formFeedback');
            form.addEventListener('submit', (e) => {
                // Let Formspree handle the actual sending. We show a success preview.
                const name = document.getElementById('contactName').value.trim();
                const email = document.getElementById('contactEmail').value.trim();
                const msg = document.getElementById('contactMessage').value.trim();
                if (!name || !email || !msg) {
                    e.preventDefault();
                    feedback.textContent = '⚠️ Please fill all fields.';
                    feedback.style.color = '#ff8888';
                    return;
                }
                feedback.innerHTML = '✨ Sending your message to adamdwilesmana11@gmail.com...';
                feedback.style.color = 'var(--neon)';
                // The form will submit to Formspree normally.
            });
        })();
    </script>
</body>
</html>
