<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Adam | Neon Portfolio</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;900&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: #0a0a0a;
            color: #e0e0e0;
            font-family: 'Poppins', sans-serif;
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* Animated background */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at 30% 30%, rgba(0, 240, 255, 0.03) 0%, transparent 30%),
                        radial-gradient(circle at 80% 70%, rgba(0, 240, 255, 0.04) 0%, transparent 40%),
                        repeating-linear-gradient(rgba(0, 240, 255, 0.02) 0px, rgba(0, 240, 255, 0.02) 1px, transparent 1px, transparent 40px),
                        repeating-linear-gradient(90deg, rgba(0, 240, 255, 0.02) 0px, rgba(0, 240, 255, 0.02) 1px, transparent 1px, transparent 40px);
            animation: slowDrift 20s infinite alternate;
        }

        @keyframes slowDrift {
            0% { transform: translate(0, 0); }
            100% { transform: translate(-10px, -10px); }
        }

        :root {
            --neon: #00f0ff;
            --neon-glow: 0 0 8px rgba(0, 240, 255, 0.7), 0 0 20px rgba(0, 240, 255, 0.4);
            --dark-bg: #0a0a0a;
            --card-bg: rgba(18, 18, 18, 0.8);
            --border-neon: 1px solid rgba(0, 240, 255, 0.3);
        }

        h1, h2, h3, .logo-text, .nav-links a, .btn, .skill-label {
            font-family: 'Orbitron', sans-serif;
            font-weight: 500;
            letter-spacing: 1px;
        }

        h2 {
            font-size: 2.5rem;
            margin-bottom: 2rem;
            text-transform: uppercase;
            position: relative;
            display: inline-block;
            color: white;
            text-shadow: var(--neon-glow);
        }

        h2:after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 60%;
            height: 3px;
            background: var(--neon);
            box-shadow: var(--neon-glow);
        }

        section {
            padding: 100px 20px;
            max-width: 1300px;
            margin: 0 auto;
            backdrop-filter: blur(3px);
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* ===== HEADER (hide on scroll) ===== */
        header {
            position: sticky;
            top: 0;
            z-index: 999;
            background: rgba(8, 8, 8, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 2px solid var(--neon);
            box-shadow: 0 4px 25px rgba(0, 240, 255, 0.3);
            clip-path: polygon(0 0, 100% 0, 98% 100%, 2% 100%);
            margin: 0 10px;
            border-radius: 0 0 20px 20px;
            transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }

        header.hide-header {
            transform: translateY(-120%);
        }

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.9rem 3rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-icon {
            font-size: 2.4rem;
            color: var(--neon);
            filter: drop-shadow(0 0 12px var(--neon));
        }

        .logo-text {
            font-size: 2.2rem;
            font-weight: 700;
            background: linear-gradient(45deg, #fff, var(--neon));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 20px var(--neon);
        }

        .nav-links {
            display: flex;
            gap: 2.2rem;
            list-style: none;
            background: rgba(0, 240, 255, 0.03);
            padding: 10px 25px;
            border-radius: 50px;
            border: 1px solid rgba(0, 240, 255, 0.25);
            backdrop-filter: blur(5px);
        }

        .nav-links a {
            text-decoration: none;
            color: #ddd;
            font-size: 1rem;
            font-weight: 500;
            transition: all 0.3s ease;
            padding-bottom: 5px;
            border-bottom: 2px solid transparent;
        }

        .nav-links a:hover {
            color: var(--neon);
            text-shadow: 0 0 8px var(--neon);
            border-bottom-color: var(--neon);
        }

        @media (max-width: 750px) {
            header {
                clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
                margin: 0;
                border-radius: 0;
            }
            .navbar {
                flex-direction: column;
                padding: 1rem 1.5rem;
                gap: 15px;
            }
            .nav-links {
                gap: 1.5rem;
                flex-wrap: wrap;
                justify-content: center;
                padding: 8px 18px;
            }
        }

        /* ===== BUTTONS ===== */
        .btn {
            display: inline-block;
            background: transparent;
            color: var(--neon);
            border: 1.5px solid var(--neon);
            padding: 12px 28px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-radius: 40px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 0 5px rgba(0, 240, 255, 0.3);
            text-decoration: none;
        }

        .btn:hover {
            background: var(--neon);
            color: #0a0a0a;
            box-shadow: 0 0 20px var(--neon), 0 0 40px rgba(0, 240, 255, 0.5);
            transform: scale(1.02);
        }

        /* ===== HOME ===== */
        .home-section {
            min-height: 90vh;
            display: flex;
            align-items: center;
        }

        .hero h1 {
            font-size: 4.5rem;
            font-weight: 700;
            color: white;
            text-shadow: 0 0 20px var(--neon), 0 0 40px rgba(0, 240, 255, 0.5);
            margin-bottom: 0.5rem;
        }

        .hero .subhead {
            font-size: 1.8rem;
            font-weight: 300;
            color: var(--neon);
            margin-bottom: 1.5rem;
            text-shadow: 0 0 10px var(--neon);
        }

        .hero .intro-text {
            font-size: 1.2rem;
            margin-bottom: 2.5rem;
            max-width: 600px;
            color: #ccc;
        }

        .glow-effect {
            animation: pulseGlow 3s infinite alternate;
        }

        @keyframes pulseGlow {
            0% { text-shadow: 0 0 5px var(--neon), 0 0 15px var(--neon); }
            100% { text-shadow: 0 0 15px #0ff, 0 0 30px #0ff, 0 0 45px #00f0ff; }
        }

        /* ===== ABOUT ===== */
        .about-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 3rem;
            align-items: center;
            background: var(--card-bg);
            padding: 3rem;
            border-radius: 20px;
            border: var(--border-neon);
            box-shadow: 0 0 30px rgba(0, 240, 255, 0.1);
            backdrop-filter: blur(8px);
        }

        .about-info h3 {
            font-size: 2rem;
            color: var(--neon);
            margin-bottom: 1rem;
        }

        .about-detail {
            font-size: 1.2rem;
            margin: 0.8rem 0;
        }

        .about-detail i {
            color: var(--neon);
            width: 30px;
            margin-right: 10px;
            text-shadow: 0 0 8px var(--neon);
        }

        .about-desc {
            margin-top: 1.5rem;
            color: #bbb;
        }

        /* ===== SKILLS ===== */
        .skills-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2.5rem;
            margin-top: 2rem;
        }

        .skill-item {
            background: var(--card-bg);
            padding: 1.8rem 1.5rem;
            border-radius: 16px;
            border: var(--border-neon);
            transition: all 0.3s;
            backdrop-filter: blur(5px);
        }

        .skill-item:hover {
            box-shadow: 0 0 30px rgba(0, 240, 255, 0.2);
            transform: translateY(-5px);
        }

        .skill-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .skill-label {
            color: white;
            font-size: 1.2rem;
        }

        .skill-percent {
            color: var(--neon);
            text-shadow: 0 0 5px var(--neon);
        }

        .progress-bar-bg {
            height: 18px;
            background: #1e1e1e;
            border-radius: 40px;
            overflow: hidden;
            box-shadow: inset 0 0 5px #000;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #00c8ff, #00f0ff);
            box-shadow: 0 0 12px var(--neon);
            border-radius: 40px;
            width: 0%;
            transition: width 1.2s ease-out;
        }

        /* ===== PORTFOLIO ===== */
        .portfolio-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
        }

        .project-card {
            background: rgba(18, 18, 18, 0.7);
            backdrop-filter: blur(8px);
            border: var(--border-neon);
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .project-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 0 30px rgba(0, 240, 255, 0.4);
            border-color: var(--neon);
        }

        .card-img {
            width: 100%;
            height: 190px;
            background: #111;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid var(--neon);
            color: var(--neon);
            font-size: 3rem;
            text-shadow: 0 0 15px;
        }

        .card-content {
            padding: 1.5rem 1.2rem 1.8rem;
        }

        .card-content h3 {
            color: var(--neon);
            margin-bottom: 0.5rem;
            font-size: 1.5rem;
        }

        .card-content p {
            color: #bbb;
            margin-bottom: 1.2rem;
        }

        .card-btn {
            background: transparent;
            border: 1px solid var(--neon);
            color: var(--neon);
            padding: 8px 18px;
            border-radius: 30px;
            font-family: 'Orbitron', sans-serif;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

        .card-btn:hover {
            background: var(--neon);
            color: black;
            box-shadow: 0 0 15px var(--neon);
        }

        /* ===== CONTACT (FIXED) ===== */
        .contact-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            background: var(--card-bg);
            padding: 2.5rem;
            border-radius: 24px;
            border: var(--border-neon);
            backdrop-filter: blur(8px);
        }

        .contact-info {
            flex: 1 1 260px;
            min-width: 0;
        }

        .contact-info h3 {
            color: var(--neon);
            margin-bottom: 1.5rem;
            font-size: 1.8rem;
        }

        .contact-item {
            margin: 1.2rem 0;
            display: flex;
            align-items: center;
            gap: 15px;
            word-break: break-word;
        }

        .contact-item i {
            font-size: 1.6rem;
            color: var(--neon);
            text-shadow: 0 0 12px;
            width: 30px;
            flex-shrink: 0;
        }

        .contact-item span {
            overflow-wrap: break-word;
            word-break: break-all;
            max-width: 100%;
        }

        .contact-form {
            flex: 2 1 300px;
            min-width: 0;
        }

        .form-group {
            margin-bottom: 1.5rem;
            width: 100%;
        }

        input, textarea {
            width: 100%;
            max-width: 100%;
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 12px;
            padding: 14px 18px;
            color: white;
            font-family: 'Poppins', sans-serif;
            transition: 0.2s;
            box-sizing: border-box;
        }

        input:focus, textarea:focus {
            outline: none;
            border-color: var(--neon);
            box-shadow: 0 0 15px rgba(0, 240, 255, 0.3);
        }

        textarea {
            min-height: 120px;
            resize: vertical;
        }

        .submit-btn {
            background: transparent;
            border: 2px solid var(--neon);
            color: var(--neon);
            padding: 14px 32px;
            font-weight: bold;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.3s;
            font-family: 'Orbitron', sans-serif;
        }

        .submit-btn:hover {
            background: var(--neon);
            color: #0a0a0a;
            box-shadow: 0 0 30px var(--neon);
        }

        .form-status {
            margin-top: 1rem;
        }

        /* ===== MODAL ===== */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal-card {
            background: #0e0e0e;
            max-width: 700px;
            width: 100%;
            border: 2px solid var(--neon);
            border-radius: 30px;
            padding: 2.5rem;
            box-shadow: 0 0 60px rgba(0, 240, 255, 0.5);
            position: relative;
            animation: modalFade 0.3s ease;
        }

        @keyframes modalFade {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 25px;
            font-size: 2rem;
            color: var(--neon);
            cursor: pointer;
        }

        .modal-close:hover {
            text-shadow: 0 0 20px var(--neon);
            transform: scale(1.1);
        }

        .modal-title {
            font-size: 2.5rem;
            color: var(--neon);
            margin-bottom: 1.5rem;
        }

        .modal-body {
            color: #ddd;
        }

        .modal-img {
            font-size: 4rem;
            color: var(--neon);
            margin-bottom: 1.5rem;
        }

        .modal-desc {
            margin: 1.5rem 0;
            line-height: 1.8;
        }

        .modal-tech {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .tech-tag {
            background: rgba(0, 240, 255, 0.1);
            border: 1px solid var(--neon);
            padding: 5px 15px;
            border-radius: 30px;
            font-size: 0.9rem;
        }

        /* ===== FOOTER ===== */
        footer {
            border-top: 1px solid rgba(0, 240, 255, 0.15);
            padding: 2.5rem 2rem;
            text-align: center;
            backdrop-filter: blur(5px);
        }

        .footer-name {
            font-size: 2rem;
            color: var(--neon);
            text-shadow: 0 0 8px;
            margin-bottom: 1rem;
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin: 1.5rem 0;
        }

        .social-links a {
            color: #ccc;
            font-size: 1.8rem;
            transition: 0.2s;
        }

        .social-links a:hover {
            color: var(--neon);
            text-shadow: 0 0 15px var(--neon);
        }

        .copyright {
            color: #888;
        }

        /* Reveal */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease, transform 0.8s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 600px) {
            h2 { font-size: 2rem; }
            .hero h1 { font-size: 3rem; }
            .hero .subhead { font-size: 1.4rem; }
            section { padding: 70px 16px; }
        }
    </style>
</head>
<body>
    <div class="bg-animation"></div>

    <!-- Modal -->
    <div class="modal-overlay" id="projectModal">
        <div class="modal-card">
            <div class="modal-close" id="closeModalBtn">&times;</div>
            <div id="modalContent"></div>
        </div>
    </div>

    <header id="mainHeader">
        <div class="navbar">
            <div class="logo-area">
                <i class="fas fa-bolt logo-icon"></i>
                <span class="logo-text">ADAM</span>
            </div>
            <ul class="nav-links">
